{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm install:*)",
      "Bash(npm ci)",
      "Bash(npm ci:*)",
      "Bash(npm run build)",
      "Bash(npm run build:*)",
      "Bash(npm run start)",
      "Bash(npm run dev)",
      "Bash(npm run clean)",
      "Bash(npm test)",
      "Bash(npm test:*)",
      "Bash(npx tsc:*)",
      "Bash(node:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git checkout -b feat/iter-*)",
      "Bash(terraform init)",
      "Bash(terraform plan)",
      "Bash(terraform plan:*)",
      "Bash(terraform validate)",
      "Bash(terraform fmt:*)",
      "Bash(terraform output:*)",
      "Bash(aws sts get-caller-identity)",
      "Bash(aws sts get-caller-identity:*)",
      "Bash(aws ecr describe-images:*)",
      "Bash(aws ecr describe-repositories:*)",
      "Bash(aws bedrock list-foundation-models:*)",
      "Bash(aws bedrock-agentcore-control list-*:*)",
      "Bash(aws logs tail:*)",
      "Bash(docker buildx version)",
      "Bash(docker images)",
      "Bash(docker ps)",
      "Bash(docker inspect:*)",
      "PowerShell(Get-ChildItem:*)",
      "PowerShell(Test-Path:*)",
      "PowerShell(Set-Location c\\:*)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "PowerShell(Remove-Item -Recurse -Force /:*)"
    ]
  }
}
