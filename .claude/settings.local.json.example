{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Copy this file to settings.local.json and customize. It's gitignored — your personal overrides won't be committed.",
  "permissions": {
    "allow": [
      "Bash(aws s3 ls:*)",
      "Bash(aws ecr get-login-password:*)"
    ]
  },
  "env": {
    "AWS_REGION": "us-east-1",
    "AWS_PROFILE": "default"
  }
}
